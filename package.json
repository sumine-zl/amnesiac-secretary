{
  "private": true,
  "name": "amnesiac-secretary",
  "description": "A secretary for amnesiacs",
  "version": "0.4.10",
  "author": "Sumine ZL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumine-zl/amnesiac-secretary.git"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && electron-builder",
    "build-dist": "vite build",
    "electron:dev": "node electron/dev.mjs",
    "electron:preview": "electron .",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest"
  },
  "build": {
    "appId": "com.sumine-zl.amnesiac-secretary",
    "productName": "Amnesiac Secretary",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "icon": "res/app.ico",
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1",
    "glob": "^13.0.6",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-singlefile": "^2.3.2",
    "vue": "^3.4.29"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.4.0",
    "vite": "^6.4.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^3.2.4"
  }
}
